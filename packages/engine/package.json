{
  "name": "@v4/engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./learn/*": "./src/learn/*.ts",
    "./core/*": "./src/core/*.ts",
    "./data/*": "./src/data/*.ts",
    "./ta/*": "./src/ta/*.ts",
    "./ml/*": "./src/ml/*.ts",
    "./modules/*": "./src/modules/*.ts",
    "./regime/*": "./src/regime/*.ts",
    "./validation/*": "./src/validation/*.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
